---
import Layout from '../../layouts/Layout.astro'
import { useTranslations } from '../../i18n'

const lang = 'en'
const t = useTranslations(lang)
type Scope = keyof typeof t.services.scopes

const trainingFlags = ['🇰🇷', '🇯🇵', '🇰🇷', '🌍', '🇰🇷']
---

<Layout lang={lang}>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <p class="hero-tag">{t.hero.tag}</p>
      <h1 class="hero-title">
        {t.hero.title}<br />
        <span class="hero-title-accent">{t.hero.title2}</span>
      </h1>
      <p class="hero-sub">{t.hero.sub}</p>
      <a href="#book" class="btn-primary">{t.hero.cta}</a>
    </div>
  </section>

  <!-- STATS -->
  <div class="stats-bar">
    <div class="container">
      <div class="stats-grid">
        {t.stats.map((stat) => (
          <div class="stat-item">
            <span class="stat-num">{stat.num}</span>
            <span class="stat-label">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- PROBLEM -->
  <section class="problem">
    <div class="container">
      <h2 class="section-title">{t.problem.title}</h2>
      <ul class="problem-list">
        {t.problem.items.map((item) => (
          <li class="problem-item">
            <span class="problem-dot" aria-hidden="true"></span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
      <p class="problem-close">{t.problem.close}</p>
    </div>
  </section>

  <!-- APPROACH -->
  <section class="approach" id="approach">
    <div class="container">
      <p class="eyebrow">{t.approach.tag}</p>
      <h2 class="approach-title">
        {t.approach.title}
        <span class="approach-title-accent">{t.approach.title2}</span>
      </h2>
      <p class="approach-desc">{t.approach.desc}</p>
      <div class="approach-grid">
        {t.approach.points.map((p, i) => (
          <div class="approach-card">
            <span class="approach-num">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="approach-label">{p.label}</h3>
            <p class="approach-text">{p.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="services" id="services">
    <div class="container">
      <h2 class="section-title">{t.services.title}</h2>
      <p class="services-sub">{t.services.sub}</p>
      {t.services.groups.map((group) => (
        <div class="section-block">
          <h3 class="section-sub-title">{group.title}</h3>
          <p class="section-sub-desc">{group.desc}</p>
          {'subgroups' in group ? (
            group.subgroups.map((sub) => (
              <div class="service-group">
                <div class="service-group-header">
                  <span class="service-group-label">{sub.label}</span>
                  <span class="service-group-desc">{sub.desc}</span>
                </div>
                <div class="self-pay-grid">
                  {sub.items.map((s) => (
                    <article class="service-card">
                      <span class="service-badge service-badge-private">
                        {t.services.scopes.private}
                      </span>
                      <h4 class="service-name">{s.name}</h4>
                      <p class="service-desc">{s.desc}</p>
                    </article>
                  ))}
                </div>
              </div>
            ))
          ) : (
            <div class={group.key === 'nhi' ? 'nhi-grid' : 'feature-grid'}>
              {group.items.map((s) => (
                <article class="service-card">
                  <span class={`service-badge service-badge-${s.scope}`}>
                    {t.services.scopes[s.scope as Scope]}
                  </span>
                  <h4 class="service-name">{s.name}</h4>
                  <p class="service-desc">{s.desc}</p>
                </article>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </section>

  <!-- PROCESS -->
  <section class="process" id="process">
    <div class="container">
      <h2 class="section-title">{t.process.title}</h2>
      <p class="process-sub">{t.process.sub}</p>

      <div class="process-type-tabs">
        <div class="process-type">
          <span class="process-type-label nhi">{t.process.nhiLabel}</span>
          <span class="process-type-note">{t.process.nhiNote}</span>
        </div>
        <div class="process-type">
          <span class="process-type-label self">{t.process.selfLabel}</span>
          <span class="process-type-note">{t.process.selfNote}</span>
        </div>
      </div>

      <div class="process-steps">
        {t.process.steps.map((step) => (
          <div class="process-step">
            <span class="process-num">{step.num}</span>
            <div class="process-content">
              <h3 class="process-title">{step.title}</h3>
              {step.desc && <p class="process-desc">{step.desc}</p>}
              {step.nhi && (
                <div class="process-split">
                  <div class="split-item nhi-item">
                    <span class="split-label">{t.process.nhiLabel}</span>
                    <p>{step.nhi}</p>
                  </div>
                  <div class="split-item self-item">
                    <span class="split-label">{t.process.selfLabel}</span>
                    <p>{step.self}</p>
                  </div>
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
      <p class="process-more">
        <a href="/en/first-visit/">{t.process.moreLink}</a>
      </p>
    </div>
  </section>

  <!-- CLINIC ENVIRONMENT -->
  <section class="clinic-env" id="clinic-env">
    <div class="container">
      <h2 class="section-title">{t.clinicEnv.title}</h2>
      <p class="clinic-env-sub">{t.clinicEnv.sub}</p>
      <div class="clinic-env-grid">
        {t.clinicEnv.images.map((img) => (
          <figure class="clinic-env-item">
            <img src={img.src} alt={img.alt} loading="lazy" decoding="async" />
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- DOCTOR -->
  <section class="doctor" id="about">
    <div class="container doctor-inner">
      <picture>
        <source srcset="/images/doctor.webp" type="image/webp" />
        <img
          src="/images/doctor.jpg"
          alt={t.doctor.title}
          class="doctor-photo"
          width="280"
          height="360"
          loading="lazy"
          decoding="async"
        />
      </picture>
      <div class="doctor-text">
        <p class="eyebrow eyebrow-light">{t.doctor.sub}</p>
        <h2 class="doctor-title">{t.doctor.title}</h2>
        <p class="doctor-desc">{t.doctor.desc}</p>
      </div>
    </div>
  </section>

  <!-- CREDENTIALS -->
  <section class="credentials" id="credentials">
    <div class="container">
      <h2 class="section-title">{t.credentials.title}</h2>
      <p class="credentials-sub">{t.credentials.sub}</p>
      <div class="credentials-grid">
        <div class="credentials-col">
          <h3 class="credentials-col-title">{t.credentials.licenses.title}</h3>
          <div class="credential-list">
            {t.credentials.licenses.items.map((item) => (
              <div class="credential-badge">
                <p class="credential-name">{item.name}</p>
                <p class="credential-note">{item.note}</p>
              </div>
            ))}
          </div>
        </div>
        <div class="credentials-col">
          <h3 class="credentials-col-title">{t.credentials.training.title}</h3>
          <div class="training-list">
            {t.credentials.training.items.map((item, i) => (
              <a
                href={item.link}
                class="training-item"
                target="_blank"
                rel="noopener"
              >
                <span class="training-country" aria-hidden="true">{trainingFlags[i]}</span>
                <div class="training-body">
                  <p class="training-name">{item.name}</p>
                  <p class="training-desc">{item.desc}</p>
                  <span class="training-read">Read full article →</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- BLOG -->
  <section class="blog-section" id="blog">
    <div class="container blog-inner">
      <div class="blog-text">
        <h2 class="section-title">{t.blog.title}</h2>
        <p class="blog-desc">{t.blog.desc}</p>
        <p class="blog-note">{t.blog.note}</p>
        <a href={t.blog.link} class="btn-primary" target="_blank" rel="noopener">
          {t.blog.cta} →
        </a>
      </div>
      <div class="blog-stat">
        <span class="blog-number">200+</span>
        <span class="blog-label">Articles</span>
      </div>
    </div>
    {t.blog.featured && (
      <div class="container">
        <div class="blog-featured">
          {t.blog.featured.map((article) => (
            <a
              href={article.url}
              class="blog-card"
              target="_blank"
              rel="noopener"
            >
              <span class="blog-card-tag">{article.tag}</span>
              <p class="blog-card-title">{article.title}</p>
              <span class="blog-card-arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </div>
    )}
  </section>

  <!-- FAQ -->
  <section class="faq" id="faq">
    <div class="container">
      <h2 class="section-title">{t.faq.title}</h2>
      <div class="faq-list">
        {t.faq.items.map((item) => (
          <details class="faq-item">
            <summary class="faq-q">{item.q}</summary>
            <p class="faq-a">{item.a}</p>
          </details>
        ))}
      </div>
      <div style="text-align:center;margin-top:1.5rem;">
        <a href="/en/first-visit/#faq" style="color:#0b3a6f;font-size:15px;border-bottom:1px solid #0b3a6f;text-decoration:none;">
          More questions? See our full FAQ →
        </a>
      </div>
    </div>
  </section>

  <!-- HOURS -->
  <section class="hours" id="hours">
    <div class="container">
      <h2 class="section-title">{t.hours.title}</h2>
      <p class="hours-note">{t.hours.note}</p>
      <div class="hours-grid">
        {t.hours.slots.map((slot) => (
          <div class="hours-row">
            <span class="hours-day">{slot.day}</span>
            <span class="hours-time">{slot.time}</span>
          </div>
        ))}
      </div>
      <p class="hours-emergency">{t.hours.emergency}</p>
    </div>
  </section>

  <!-- BOOK -->
  <section class="book" id="book">
    <div class="container book-inner">
      <h2 class="book-title">{t.book.title}</h2>
      <p class="book-sub">{t.book.sub}</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin:0 auto;">
        <a href="https://line.me/R/ti/p/@twmedpro"
           style="display:inline-flex;align-items:center;gap:8px;background-color:#1a2f5e;color:#ffffff;padding:14px 28px;border-radius:6px;font-size:15px;font-weight:600;text-decoration:none;letter-spacing:0.03em;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.630 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
          Book via LINE
        </a>
        <a href="https://wa.me/886900000000"
           style="display:inline-flex;align-items:center;gap:8px;background-color:#25d366;color:#ffffff;padding:14px 28px;border-radius:6px;font-size:15px;font-weight:600;text-decoration:none;letter-spacing:0.03em;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Book via WhatsApp
        </a>
      </div>
      <p style="margin-top:12px;font-size:14px;color:#6b7280;">
        Or <a href="mailto:info@golanclinic.com" style="color:#0b3a6f;">email us</a>
      </p>
      <figure class="book-qr">
        <img src="/images/line-qr.png" alt={t.book.qrLabel} width="180" height="180" loading="lazy" />
        <figcaption>{t.book.qrLabel}</figcaption>
      </figure>
      <p class="book-addr">{t.book.addr}</p>
      <a href={t.book.mapLink} class="map-link" target="_blank" rel="noopener">
        {t.book.mapLabel}
      </a>
      <p class="book-hours">{t.book.hours}</p>
    </div>
  </section>
</Layout>
